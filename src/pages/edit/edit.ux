  display: flex;
  align-items: center;
  padding-left:30px;
  padding-top:30px;
  padding-right:30px; 
  width:100%;
}
.demo-page {
  flex-direction: column;
  justify-content:flex-start;
  align-items:flex-start;
  padding-bottom: 50px;
}

.title {
  color:white;
  font-size: 50px;
  text-align: center;
  font-weight:bold;
}
.subTitle {
  color:white;
  font-size: 35px;
  text-align: center;
  font-weight:bold;
}
.tipsText{
  color:#cccccc;
  font-size:25px;
}
.btn {
  width: 50%;
  height: 80px;
  margin-top: 5%;
  border-radius: 20px;
  background-color: #222222;
  font-size: 30px;
  color: #ffffff;
}
.goBackBtn {
  margin-right:10px;
  width: 50px;
  height: 50px;
  border-radius: 50%;
  background-color: #333333;
  border: 2px solid #666666;
  text-align: center;
  font-size: 24px;
  color: #cccccc;
  line-height: 40px;
}
.selected {
  background-color:royalblue;
}
.leftBtn{
  margin-right:2.5%;
}
.rightBtn{
  margin-left:2.5%;
}
