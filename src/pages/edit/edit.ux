<template>
  <div class="demo-page">
    <div class="banner">
      <text class="goBackBtn" onclick="routeHome">←</text>
      <text class="title" >编辑页面</text>
    </div>

    <div style="height:20px"></div>

    <div class="menu">
      <text class="subTitle">编辑卡片</text>
      <text class="tipsText">点击对应选项显隐卡片</text>
      <div>
        <input class="btn leftBtn" type="button" value="全球排名"/>
        <input class="btn rightBtn" type="button" value="当前pp"/>
      </div>
      <div>
        <input class="btn leftBtn" type="button" value="准确率"/>
        <input class="btn rightBtn" type="button" value="游玩次数"/>
      </div>
    </div>

    <div style="height:20px"></div>
    <div class="menu">
      <text class="subTitle">游戏模式</text>
      <text class="tipsText">选择你要显示的游戏模式的数据</text>
        <div>
          <input class="btn {{currMode === '0'?'selected':''}} leftBtn" type="button" value="osu!" onclick="setAppMode('0')" />
          <input class="btn {{currMode === '1'?'selected':''}} rightBtn" type="button" value="taiko" onclick="setAppMode('1')" />
        </div>
        <div>
          <input class="btn {{currMode === '2'?'selected':''}} leftBtn" type="button" value="catch" onclick="setAppMode('2')" />
          <input class="btn {{currMode === '3'?'selected':''}} rightBtn" type="button" value="mania" onclick="setAppMode('3')" />
        </div>
    </div>
  </div>

</template>

<script>
import router from "@system.router"
import prompt from "@system.prompt"
import storage from "@system.storage"
export default {
  private:{
    currMode:'-1'
  },
  onShow(){
  storage.get({
    key: 'osuMode',
    success: (data) => {
      this.currMode=data
      console.log('读取到模式属性 mode=' + this.currMode)
    },
    fail: function(data, code) {
      console.log(`未读取到模式属性 ${code}`)
    }
})
  },
  setAppMode(mode){
    storage.set({
    key: 'osuMode',
    value: mode,
    success: (data) => {
      this.currMode = mode;
      if(mode==='0') prompt.showToast({message:'已设置为osu!standard模式'});
      if(mode==='1') prompt.showToast({message:'已设置为osu!Taiko模式'});
      if(mode==='2') prompt.showToast({message:'已设置为osu!catch模式'});
      if(mode==='3') prompt.showToast({message:'已设置为osu!mania模式'});
   },
    fail: function(data, code) {
      prompt.showToast({message:`发生未知错误：${code}`})
    }
})
  },
  routeHome(){
    router.back({
      uri:"/pages/index"
    })
  },
}
</script>

