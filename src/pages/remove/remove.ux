.defaultText{
  color:gold;
  font-size: 25px;
  text-align: left;
  font-weight:bold;
}
.menu{
  display:flex;
  flex-direction: column;
  justify-content:flex-start;
  align-items:flex-start;
  padding-left:30px;
  padding-right:30px;
  width:100%
}
.banner{
  flex-direction: column;
  display: flex;
  align-items: center;
  padding-left:30px;
  padding-top:30px;
  padding-right:30px; 
  width:100%;
}
.demo-page {
  padding-top: 30px;
  flex-direction: column;
  justify-content:center;
  align-items:center;
}

.title {
  color:white;
  font-size: 40px;
  text-align: center;
  font-weight:bold;
}

