<template>
  <div class="demo-page">
    <div class="banner">
      <text class="title">确定删除用户信息吗</text>
      <text></text>
      <text class="defaultText">将清空API Key信息和UID信息</text>
      <text class="defaultText">此操作不可逆，请三思而后行</text>
      <text class="defaultText">应用将退出以应用更改</text>
      <text></text>
    </div>
    <div class="menu">
      <input class="btn" type="button" value="是的，我确定" onclick="delUser" style="color:red"/>
      <input class="btn" type="button" value="不，请不要这么做" onclick="exit" />
    </div>
  </div>

</template>

<script>
import router from "@system.router"
import prompt from "@system.prompt"
import storage from "@system.storage"
export default {
  exit() {
    router.back({
      uri: "/pages/config"
    })
  },
 async delUser(){
  const removeStorage = (key) => {
      return new Promise((resolve) => {
        storage.delete({
          key: key,
          success: () => {
            console.log(`已清除: ${key}`);
            resolve(true);
          },
          fail: (data, code) => {
            console.log(`清除 ${key} 失败: ${code}`);
            resolve(false); // 即使失败也 resolve，避免 Promise.all 挂起
          }
        });
      });
    };

    //执行删除操作
    await Promise.all([
      removeStorage('osuKeyStoraged'),
      removeStorage('osuUIDStoraged')
    ]);

    prompt.showToast({message: '配置已清空'});
    this.exit();
    this.$app.exit();
  }

  }
</script>

